(module
  (import "wasi_snapshot_preview1" "fd_write" (func $fd_write (param i32 i32 i32 i32) (result i32)))
  (memory (export "memory") 1)
  (data (i32.const 0) "\08\00\00\00\01\00\00\00")
  (data (i32.const 8) "\n")
  (data (i32.const 16) "\00\00\01\00\00\00")
  (func $print (param $num i32)
    (loop $print
        (i32.store8 (i32.const 8) (i32.add (i32.rem_u (local.get $num) (i32.const 10)) (i32.const 0x30)))
        (call $fd_write (i32.const 1) (i32.const 0) (i32.const 1) (i32.const 100))
        (drop)
        (local.set $num (i32.div_u (local.get $num) (i32.const 10)))
        (br_if $print (i32.ne (local.get $num) (i32.const 0)))
    )
        (i32.store8 (i32.const 8) (i32.const 10))
        (call $fd_write (i32.const 1) (i32.const 0) (i32.const 1) (i32.const 100))
        (drop)
    )
  (func (export "_start")
        (i32.load offset=2 (i32.const 16))
        (call $print)
  )
)
